function generateResume() {
  const skills =
    document.getElementById("skills").value ||
    "communication, organization, teamwork, and problem solving";
  const experience =
    document.getElementById("experience").value ||
    "customer service, academic projects, and workplace responsibilities";
  const activities =
    document.getElementById("activities").value ||
    "clubs, volunteer work, leadership, or campus involvement";

  const output = `
Professional Summary:
Motivated candidate with experience in ${experience}. Skilled in ${skills}. Strong background in ${activities}.

Sample Resume Bullets:
• Applied ${skills} to complete responsibilities efficiently and support team goals.
• Gained hands-on experience in ${experience} while managing multiple priorities.
• Demonstrated leadership, reliability, and professionalism through ${activities}.
`;

  document.getElementById("resumeOutput").style.display = "block";
  document.getElementById("resumeOutput").innerText = output;
}

function analyzeResume() {
  const resume = document.getElementById("resumeText").value.trim();

  if (!resume) {
    alert("Please paste your resume text first.");
    return;
  }

  const strengths = [];
  const fixes = [];
  const tips = [];

  if (resume.length > 400) {
    strengths.push("Your resume includes a solid amount of information.");
  } else {
    fixes.push("Your resume may be too short or missing important details.");
    tips.push("Add more specific responsibilities, skills, and accomplishments.");
  }

  if (resume.match(/\d/)) {
    strengths.push("You included numbers, which helps show measurable impact.");
  } else {
    fixes.push("Your resume does not include measurable numbers.");
    tips.push(
      "Add numbers such as customers served, team size, sales amounts, or percentages."
    );
  }

  if (resume.toLowerCase().includes("skills")) {
    strengths.push("You included a Skills section.");
  } else {
    fixes.push("You may be missing a clear Skills section.");
    tips.push(
      "Add a Skills section with software, communication, leadership, and job-related keywords."
    );
  }

  if (resume.includes("I ") || resume.includes("my ")) {
    fixes.push("Your resume uses first-person language.");
    tips.push(
      "Remove words like I, me, and my. Resume bullets should be direct and action-focused."
    );
  }

  document.getElementById("resultsSection").style.display = "block";
  document.getElementById("strengths").innerHTML = makeList(strengths);
  document.getElementById("fixes").innerHTML = makeList(fixes);
  document.getElementById("tipsOutput").innerHTML = makeList(tips);
  document.getElementById("highlightedResume").innerHTML = highlightIssues(resume);

  feedbackReport = `AI Resume Feedback Report

WHAT LOOKS STRONG:
${strengths.map((item) => "- " + item).join("\n")}

WHAT NEEDS TO BE FIXED:
${fixes.map((item) => "- " + item).join("\n")}

TIPS TO IMPROVE:
${tips.map((item) => "- " + item).join("\n")}
`;
}

function improveBulletPoint() {
  const bulletEl = document.getElementById("bulletInput");
  const outputEl = document.getElementById("bulletOutput");
  const raw = (bulletEl.value || "").trim();

  if (!raw) {
    outputEl.style.display = "block";
    outputEl.innerText = "Paste a bullet point first, then click Improve Bullet Point.";
    return;
  }

  const cleaned = raw
    .replace(/^[-•]\s*/, "")
    .replace(/\bhelped\b/gi, "supported")
    .replace(/\bworked on\b/gi, "contributed to")
    .replace(/\bresponsible for\b/gi, "")
    .replace(/\s{2,}/g, " ")
    .trim();

  const improved =
    cleaned.charAt(0).toUpperCase() +
    cleaned.slice(1) +
    " while improving efficiency, communication, and service quality.";

  outputEl.style.display = "block";
  outputEl.innerText = `Original:\n${raw}\n\nImproved:\n${improved}`;
}

function analyzeAtsMatch() {
  const resumeText = (document.getElementById("atsResumeText").value || "").toLowerCase();
  const jobText = (document.getElementById("jobDescriptionText").value || "").toLowerCase();

  if (!resumeText.trim() || !jobText.trim()) {
    alert("Please paste both resume text and job description.");
    return;
  }

  const keywordBank = [
    "communication",
    "leadership",
    "customer service",
    "teamwork",
    "time management",
    "problem solving",
    "project management",
    "microsoft office",
    "excel",
    "data entry",
    "organization",
    "scheduling",
    "analysis",
    "sales",
    "collaboration",
    "training",
    "reporting",
    "administrative support",
  ];

  const jdKeywords = keywordBank.filter((k) => jobText.includes(k));
  const matched = jdKeywords.filter((k) => resumeText.includes(k));
  const missing = jdKeywords.filter((k) => !resumeText.includes(k));

  const suggestedPoints = missing.slice(0, 6).map(
    (k) => `Add a bullet with measurable impact using "${k}" in a natural, truthful way.`
  );

  const scoreBase = jdKeywords.length || 1;
  const matchScore = Math.round((matched.length / scoreBase) * 100);

  document.getElementById("atsResults").style.display = "block";
  document.getElementById("atsMatched").innerHTML = makeList(
    matched.length ? matched : ["No direct matches found yet."]
  );
  document.getElementById("atsMissing").innerHTML = makeList(
    missing.length ? missing : ["Great job. You covered the major keywords found in this posting."]
  );
  document.getElementById("atsPoints").innerHTML = makeList(
    suggestedPoints.length
      ? suggestedPoints
      : ["Focus on stronger metrics (numbers/percentages) to improve recruiter visibility."]
  );
  document.getElementById("atsScoreOutput").innerText =
    `Estimated ATS Keyword Match Score: ${matchScore}%\n` +
    `Matched ${matched.length} of ${jdKeywords.length || 0} high-value keywords found in the job description.`;
}

function makeList(items) {
  if (items.length === 0) {
    return "<p>No major issues found.</p>";
  }

  return "<ul>" + items.map((item) => "<li>" + item + "</li>").join("") + "</ul>";
}

function highlightIssues(text) {
  let highlighted = text;
  highlighted = highlighted.replaceAll("I ", "<span class='highlight'>I </span>");
  highlighted = highlighted.replaceAll("my ", "<span class='highlight'>my </span>");
  highlighted = highlighted.replaceAll("helped", "<span class='highlight'>helped</span>");
  highlighted = highlighted.replaceAll("worked", "<span class='highlight'>worked</span>");
  highlighted = highlighted.replaceAll(
    "responsible for",
    "<span class='highlight'>responsible for</span>"
  );
  return highlighted;
}

function downloadFeedback() {
  if (!feedbackReport) {
    alert("Please analyze your resume first.");
    return;
  }

  const element = document.createElement("a");
  const file = new Blob([feedbackReport], { type: "text/plain" });

  element.href = URL.createObjectURL(file);
  element.download = "AI_Resume_Feedback_Report.txt";

  document.body.appendChild(element);
  element.click();
  document.body.removeChild(element);
}

